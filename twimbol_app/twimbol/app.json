{
  "expo": {
    "name": "Twimbol",
    "slug": "twimbol",
    "version": "1.1.0",
    "newArchEnabled": true,
    "icon": "./assets/icons/logo_icon.png",
    "splash": {
      "image": "./assets/icons/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/icons/logo_icon.png"
    },
    "experiments": {
      "typedRoutes": true
    },
    "jsEngine": "hermes",
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "d650d771-8562-4473-8d6a-f00fb4c274ef"
      }
    },
    "android": {
      "package": "com.app.rafid.innoverse",
      "icon": "./assets/icons/logo_icon.png",
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "https",
              "host": "twimbol.com",
              "pathPrefix": "/"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "scheme": "twimbol",
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      "expo-build-properties",
      "./withVisionCameraFix.js",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 36,
            "targetSdkVersion": 36
          }
        }
      ]
    ],
    "userInterfaceStyle": "light",
    "ios": {
      "bundleIdentifier": "com.app.rafid.innoverse",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    }
  }
}
